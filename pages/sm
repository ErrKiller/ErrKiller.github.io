<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>玄机阁 - 专业命理分析系统</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Noto Serif SC', serif;
            background: radial-gradient(circle at 10% 20%, rgba(66, 78, 100, 0.1) 0%, transparent 20%),
            radial-gradient(circle at 90% 80%, rgba(66, 78, 100, 0.1) 0%, transparent 20%),
            linear-gradient(135deg, #1a2a6c 0%, #b21f1f 50%, #1a2a6c 100%);
            color: #fff;
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="none" stroke="%23ffffff" stroke-width="0.5" opacity="0.1"/></svg>');
            pointer-events: none;
        }

        .container {
            max-width: 100%;
            margin: 0 auto;
            padding: 15px;
            position: relative;
            z-index: 1;
        }

        .header {
            text-align: center;
            margin-bottom: 25px;
            padding: 15px;
        }

        .logo {
            font-size: 2.5rem;
            margin-bottom: 8px;
            text-shadow: 0 0 20px rgba(255, 255, 255, 0.5);
            letter-spacing: 2px;
        }

        .subtitle {
            font-size: 1rem;
            opacity: 0.8;
            margin-bottom: 15px;
        }

        .main-card {
            background: rgba(25, 25, 35, 0.85);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 25px 20px;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 20px;
        }

        .input-section {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-bottom: 25px;
        }

        .input-group {
            width: 100%;
        }

        label {
            display: block;
            margin-bottom: 6px;
            font-weight: bold;
            color: #e0e0e0;
            font-size: 0.95rem;
        }

        input, select {
            width: 100%;
            padding: 12px 15px;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            background: rgba(0, 0, 0, 0.3);
            color: white;
            font-size: 16px;
            height: 48px;
        }

        input:focus, select:focus {
            outline: none;
            border-color: #3498db;
            box-shadow: 0 0 10px rgba(52, 152, 219, 0.3);
        }

        .calculate-btn {
            background: linear-gradient(45deg, #3498db, #8e44ad);
            color: white;
            border: none;
            padding: 15px;
            font-size: 1.1rem;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 15px;
            width: 100%;
            font-weight: bold;
            letter-spacing: 1px;
            height: 50px;
        }

        .calculate-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
        }

        .calculate-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .result-container {
            display: none;
            margin-top: 25px;
            animation: fadeIn 0.8s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .result-card {
            background: rgba(0, 0, 0, 0.7);
            border-radius: 15px;
            padding: 25px 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .result-title {
            text-align: center;
            font-size: 1.8rem;
            margin-bottom: 25px;
            color: #f39c12;
            text-shadow: 0 0 10px rgba(243, 156, 18, 0.5);
        }

        .fortune-section {
            margin-bottom: 20px;
        }

        .section-title {
            font-size: 1.3rem;
            color: #3498db;
            margin-bottom: 12px;
            border-bottom: 2px solid rgba(52, 152, 219, 0.3);
            padding-bottom: 6px;
        }

        .section-content {
            line-height: 1.7;
            color: #ecf0f1;
            font-size: 1rem;
        }

        .lucky-info {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            margin-top: 15px;
        }

        .lucky-item {
            background: rgba(52, 152, 219, 0.2);
            padding: 12px 8px;
            border-radius: 8px;
            margin: 8px 4px;
            min-width: 90px;
            text-align: center;
        }

        .lucky-label {
            font-size: 0.8rem;
            opacity: 0.8;
            margin-bottom: 4px;
        }

        .lucky-value {
            font-size: 1.1rem;
            color: #f1c40f;
            font-weight: bold;
        }

        .loading {
            display: none;
            text-align: center;
            padding: 30px 20px;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border: 4px solid rgba(255, 255, 255, 0.1);
            border-top: 4px solid #3498db;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 15px;
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }
            100% {
                transform: rotate(360deg);
            }
        }

        .footer-note {
            text-align: center;
            margin-top: 20px;
            font-size: 0.85rem;
            opacity: 0.6;
            padding: 0 10px;
        }

        /* 移动端优化 */
        @media (max-width: 768px) {
            .logo {
                font-size: 2.2rem;
            }

            .main-card {
                padding: 20px 15px;
            }

            .result-title {
                font-size: 1.6rem;
            }

            .section-title {
                font-size: 1.2rem;
            }

            .lucky-item {
                min-width: 80px;
                padding: 10px 6px;
            }
        }

        @media (max-width: 480px) {
            .logo {
                font-size: 2rem;
            }

            .subtitle {
                font-size: 0.9rem;
            }

            .input-group {
                margin-bottom: 10px;
            }

            label {
                font-size: 0.9rem;
            }

            input, select {
                font-size: 16px; /* 防止iOS缩放 */
            }

            .result-title {
                font-size: 1.4rem;
            }

            .section-title {
                font-size: 1.1rem;
            }

            .section-content {
                font-size: 0.95rem;
            }

            .lucky-item {
                min-width: 70px;
                padding: 8px 5px;
            }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <div class="logo">🔮 玄机阁 🔮</div>
        <div class="subtitle">专业命理分析系统</div>
    </div>

    <div class="main-card">
        <div class="input-section">
            <div class="input-group">
                <label for="name">姓名</label>
                <input type="text" id="name" placeholder="请输入您的姓名(可选)">
            </div>

            <div class="input-group">
                <label for="gender">性别</label>
                <select id="gender">
                    <option value="male">男</option>
                    <option value="female">女</option>
                </select>
            </div>

            <div class="input-group">
                <label for="birthDate">出生日期</label>
                <input type="date" id="birthDate">
            </div>
        </div>

        <button class="calculate-btn" onclick="calculateFortune()">开启命运之门</button>

        <div class="loading" id="loading">
            <div class="spinner"></div>
            <div>正在为您解读天机...</div>
        </div>

        <div class="result-container" id="resultContainer">
            <div class="result-card">
                <div class="result-title" id="resultTitle">命理分析报告</div>
                <div id="fortuneResult"></div>
            </div>
        </div>
    </div>

    <div class="footer-note">
        <p>© TYF</p>
    </div>
</div>

